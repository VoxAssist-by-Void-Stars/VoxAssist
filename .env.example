MONGODB_URI=
VOYAGE_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional Clerk URLs (defaults work for most apps)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# AI factory: "true" = always mocks; "false" = try real teammate modules
USE_MOCK_AI=true
# When USE_MOCK_AI=false, fall back to mocks if real retriever/generator fail
AI_FALLBACK_TO_MOCK=true

# Demo identity: map Clerk userId -> vault owner (comma-separated userId:owner pairs)
# Example: CLERK_OWNER_MAP=user_abc:momen,user_def:rayan
CLERK_OWNER_MAP=

# Rate limit for live LLM calls (requests per window per user); 0 disables
LLM_RATE_LIMIT_PER_MINUTE=30

# HTTP /api/ingest (prefer CLI); leave false in production
ALLOW_HTTP_INGEST=false
