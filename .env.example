# Mock mode: `true` (default) runs the app on mock AI with no external keys.
# Set to `false` to wire real retrieval + synthesis (requires the keys below).
USE_MOCK_AI=true

# Anthropic — the only synthesis LLM. Small/fast model for `ask`, Opus for `plan`.
ANTHROPIC_API_KEY=
# Optional: custom Anthropic-compatible endpoint
ANTHROPIC_BASE_URL=
CLAUDE_ASK_MODEL=claude-haiku-4-5-20251001
CLAUDE_PLAN_MODEL=claude-opus-4-8

# MongoDB Atlas (vector store)
# Create a cluster, enable Atlas Vector Search, then paste the Node driver SRV string:
MONGODB_URI=
MONGODB_DB=voxassist

# Voyage (embeddings)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5
EMBEDDING_DIM=1024

# Clerk auth (if using real sign-in instead of fake username entry)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
